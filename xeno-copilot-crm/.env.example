# ─────────────────────────────────────────────────────────────────────────────
# Xeno Copilot — CRM Service Environment Variables
# Copy this file to .env and fill in all values before running locally.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/xeno-copilot?retryWrites=true&w=majority
MONGODB_URI=

# Google Gemini API key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Bearer token for API authentication (64 hex characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_TOKEN=

# URL of the Channel Service (used to verify callbacks originate from it)
CHANNEL_SERVICE_URL=http://localhost:3002

# Frontend origin for CORS
FRONTEND_URL=http://localhost:3000

# MongoDB ObjectId of the Raga demo brand (populated after running seed.ts)
DEMO_BRAND_ID=

# Server port
PORT=3001

# Environment
NODE_ENV=development

# Override minimum hours before post-campaign report runs (set 0 for demo/dev)
REPORT_MIN_HOURS_AFTER_COMPLETION=0

# SendGrid sender address (used when dispatching email campaigns)
SENDGRID_FROM_EMAIL=noreply@example.com
